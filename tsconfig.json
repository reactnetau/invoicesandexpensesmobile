{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "app.config.ts",
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.d.ts"
  ],
  "exclude": [
    "amplify",
    "node_modules"
  ]
}
