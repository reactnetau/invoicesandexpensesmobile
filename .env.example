# ── Expo / React Native ──────────────────────────────────────────────────────
# Stripe publishable key (safe to expose in the client)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Public app URL — used in invoice PDF/email links
# Set to your production domain once deployed
EXPO_PUBLIC_APP_URL=https://invoicesandexpenses.com

# ── Amplify Gen 2 (auto-populated from ../invoicesandexpensesbackend) ─────────
# These are injected by Amplify; you do NOT set these manually.
# AMPLIFY_DATA_GRAPHQL_ENDPOINT=https://...appsync-api.us-east-1.amazonaws.com/graphql
# AMPLIFY_DATA_API_KEY=da2-...

# ── Backend secrets ───────────────────────────────────────────────────────────
# Never put real values here. Set them from ../invoicesandexpensesbackend:
#   npx ampx sandbox secret set STRIPE_SECRET_KEY
#   npx ampx sandbox secret set STRIPE_PRICE_ID
#   npx ampx sandbox secret set STRIPE_WEBHOOK_SECRET
#   npx ampx sandbox secret set ANTHROPIC_API_KEY
#   npx ampx sandbox secret set ENCRYPTION_KEY
#   npx ampx sandbox secret set SES_FROM_EMAIL
#   npx ampx sandbox secret set FOUNDING_MEMBERS

# ── Production Secrets (set in AWS Parameter Store or Amplify Console) ────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...          ($7/month Pro plan)
# STRIPE_WEBHOOK_SECRET=whsec_...
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ENCRYPTION_KEY=<64 hex chars — 32 bytes for AES-256-GCM>
# SES_FROM_EMAIL=no-reply@invoicesandexpenses.com
# FOUNDING_MEMBERS=true              (set to false once 50 founding members reached)
