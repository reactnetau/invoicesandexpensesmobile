# RevenueCat public SDK keys (safe to expose in the client)
# Use the platform public SDK keys from the same RevenueCat project.
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=

# Use the exact RevenueCat entitlement identifier, not the display name.
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro

# Optional: set this only if you do not want to use RevenueCat's current offering.
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=

# Public app URL used in invoice PDF/email links.
EXPO_PUBLIC_APP_URL=https://invoicesandexpenses.com

# Optional build numbers for dynamic Expo config.
# Increase IOS_BUILD_NUMBER for every App Store/TestFlight upload.
IOS_BUILD_NUMBER=1
ANDROID_VERSION_CODE=1
